# Server
NODE_ENV=development
PORT=8000

# Database (MySQL or PostgreSQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=legal_crm

# For PostgreSQL use:
# DB_TYPE=postgres
# DB_PORT=5432

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@legalcrm.com

# File Upload (max size for multipart bodies; files go to Cloudinary)
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
# 10MB in bytes

# Cloudinary (photos, media, firm logos, matter docs, KYC uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional prefix for asset public_ids (default: legal-crm)
CLOUDINARY_FOLDER=legal-crm

# App
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
